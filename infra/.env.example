# Phase 3.2 — copy to `.env` (same dir) and fill in. NEVER commit the real .env.
# After creating it on the box: chmod 600 .env

# --- Postgres ---
PG_USER=n8n
PG_DB=n8n
# generate: openssl rand -base64 24
PG_PASS=CHANGE_ME_strong_db_password

# --- n8n ---
# the subdomain you pointed at this box (must match the Caddyfile site address)
N8N_HOST=flow.yourbrand.in
# 32+ random chars; encrypts stored credentials. LOSE THIS = lose all saved creds.
# generate: openssl rand -hex 24
N8N_KEY=CHANGE_ME_32plus_random_chars

# --- Render worker ---
# Default plan: Remotion runs on the host under pm2, so n8n reaches it via host-gateway.
# If you instead containerize render with the `render` profile, set http://render:4000
RENDER_URL=http://host.docker.internal:4000

# --- ElevenLabs (Phase 2.2 — the anchor voice) ---
# Get the API key from the ElevenLabs dashboard. VOICE_ID is the ONE voice you lock
# forever (see assets/brand/voice/elevenlabs-voice-guide.md for how to find it).
ELEVENLABS_API_KEY=CHANGE_ME_elevenlabs_api_key
ELEVENLABS_VOICE_ID=CHANGE_ME_locked_voice_id

# --- Telegram (Phase 4 — approval gate) ---
TELEGRAM_CHAT_ID=CHANGE_ME_your_chat_id

# --- AWS / assets (Phase 3) ---
ASSETS_BUCKET=yourbrand-assets
AWS_REGION=ap-south-1
# --- Analytics (Phase 5, Workflow D) ---
ANALYTICS_SHEET_ID=CHANGE_ME_google_sheet_id
